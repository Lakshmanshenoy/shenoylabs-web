# GitHub-backed Tina settings
# Create a GitHub Personal Access Token with `repo` scope and set it here for the server to create branches/PRs
GITHUB_TOKEN=ghp_xxx
# Repository in owner/repo format
GITHUB_REPOSITORY=owner/repo
# Optional: base branch to open PRs against
GITHUB_BASE_BRANCH=main

# Local-only option (already available): the isomorphic git bridge requires no token
# RUN: pnpm run tina (uses isomorphic git bridge)
# Contact form email delivery (Resend)
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Shenoy Labs <onboarding@resend.dev>
CONTACT_TO_EMAIL=shenoylabs@gmail.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_RAZORPAY_PAYMENT_BUTTON_ID=

# Public site metadata + analytics
NEXT_PUBLIC_SITE_URL=https://shenoylabs.com
NEXT_PUBLIC_SITE_NAME=Shenoy Labs
NEXT_PUBLIC_SITE_DESCRIPTION=Research, tools, and projects built in public by Lakshman Shenoy.
NEXT_PUBLIC_SITE_AUTHOR=Lakshman Shenoy
NEXT_PUBLIC_CONTACT_EMAIL=shenoylabs@gmail.com
NEXT_PUBLIC_OG_IMAGE=/og-default.svg
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
