# Example .env.local for local development — copy to .env.local and fill secrets
# Do NOT commit real tokens to source control.

# GitHub settings for Tina admin -> PR flow
GITHUB_TOKEN=ghp_replace_with_your_token
TINA_GITHUB_TOKEN=ghp_replace_with_your_token  # optional alias used by some helpers
GITHUB_REPOSITORY=owner/repo
GITHUB_BASE_BRANCH=main

# Next.js / app settings
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: consent admin key for testing consent endpoints
CONSENT_ADMIN_KEY=changeme

# Optional Upstash (used by consent endpoints in production)
# UPSTASH_URL=
# UPSTASH_TOKEN=
# UPSTASH_KEY=

# Usage: copy this file to `.env.local` and fill values before running locally.# Example environment variables for local development and GitHub-backed Tina integration
# Copy this file to `.env.local` and fill in your real values (do NOT commit secrets).

# GitHub token with repo scope (or set TINA_GITHUB_TOKEN)
GITHUB_TOKEN=ghp_xxx
TINA_GITHUB_TOKEN=ghp_xxx

# Repository in owner/repo format
GITHUB_REPOSITORY=owner/repo

# Base branch for PRs
GITHUB_BASE_BRANCH=main

# Base URL used when calling internal endpoints from server-side code
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Tina client / build tokens (for Tina Cloud flows)
NEXT_PUBLIC_TINA_CLIENT_ID=your_tina_client_id
TINA_TOKEN=your_tina_token
