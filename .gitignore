# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
dev-console-network.log

# Editor / local IDE
.vscode/

# GH CLI run logs and archives
.gh_run*
.gh_run_logs_*.zip

# TinaCMS
/admin/
/.tina/
# Avoid committing server-side PR logs and optional built admin artifacts
data/tina-media-prs.json
public/admin/
.eslintcache
