{
  "name": "shenoylabs-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:tina": "tinacms dev --isomorphicGitBridge -c \"next dev\"",
    "test": "vitest",
    "build": "next build",
    "build:tina": "tinacms build && next build",
    "tina": "tinacms dev --isomorphicGitBridge -c \"next dev\"",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check": "bash ./scripts/checks.sh",
    "validate:featured": "node ./scripts/validate-featured.mjs",
    "pnpm:approve-builds": "pnpm approve-builds",
    "purge:consent": "node scripts/purge_old_consent.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@marsidev/react-turnstile": "^1.5.0",
    "@tinacms/datalayer": "^2.0.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "reading-time": "^1.5.0",
    "tailwind-merge": "^3.5.0",
    "tinacms": "^3.7.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tinacms/cli": "^2.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "pnpm": ">=10"
  }
}
